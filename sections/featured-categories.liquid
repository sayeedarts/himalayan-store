{% render 'section-style' %}
<section
  class="container container-xxl pt-14 featured-categories-section"
  id="shopify-section-{{ section.id }}"
>
  <div class="mb-lg-13 mb-7">
    <div class="text-center">
      {% if section.settings.heading != blank %}
        <h2 class="mb-6">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="fs-18px mb-0">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  </div>
  <div class="row">
    {% for block in section.blocks %}
      {% liquid
        assign collection = block.settings.collection
        assign item_title = block.settings.title | default: collection.title
        assign item_link = block.settings.link | default: collection.url
        assign item_count = block.settings.count | default: collection.all_products_count

        assign item_image = block.settings.image | default: collection.featured_image
        assign item_image_dark = block.settings.image_dark | default: item_image
      %}
      <div class="col-lg-2 col-md-2 col-6" {{ block.shopify_attributes }}>
        <div class="card border-0 fw-semibold">
          <a
            href="{{ item_link }}"
            class="rounded-circle mx-auto hover-zoom-in w-100 image-box-1"
            style="max-width: 160px; display: block;"
          >
            {% if item_image != blank %}
              {{
                item_image
                | image_url: width: 320
                | image_tag: class: 'lazy-image img-fluid card-img light-mode-img', loading: 'lazy', alt: item_title
              }}
              {{
                item_image_dark
                | default: item_image
                | image_url: width: 320
                | image_tag: class: 'lazy-image dark-mode-img img-fluid card-img', loading: 'lazy', alt: item_title
              }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'img-fluid card-img rounded-circle' }}
            {% endif %}
          </a>
          <div class="card-body pt-9 pb-0 d-flex justify-content-center px-0">
            <h4 class="fs-5 text-center position-relative">
              <a href="{{ item_link }}" class="text-decoration-none">{{ item_title }}</a>
              {% if item_count != blank %}
                <span class="fw-bold fs-14px position-absolute top-0 me-n6 mt-n3 end-0 top-50 translate-middle-y">
                  {{ item_count }}
                </span>
              {% endif %}
            </h4>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

