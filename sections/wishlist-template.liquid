<div class="container py-10 py-lg-15">
  <div class="row mb-10">
    <div class="col-12 text-center">
      <h1 class="mb-5">{{ page.title }}</h1>
    </div>
  </div>

  <div class="row" id="wishlist-grid">
    <!-- Wishlist items will be injected here via JS -->
    <div class="col-12 text-center py-10" id="wishlist-loading">
      <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
      </div>
    </div>
    <div class="col-12 text-center d-none" id="wishlist-empty">
      <p class="mb-4">Your wishlist is currently empty.</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">Continue Shopping</a>
    </div>
  </div>
</div>

<script src="{{ 'wishlist.js' | asset_url }}" defer></script>
{% schema %}
{
  "name": "Wishlist Page",
  "settings": [],
  "presets": [
    {
      "name": "Wishlist Page"
    }
  ]
}
{% endschema %}
