{% render 'section-style' %}
{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}

<style>
  .hero-slider-section .swiper-button-next,
  .hero-slider-section .swiper-button-prev {
    color: #000;
    top: 50%;
    right: 50px;
    left: auto;
    border-radius: 50%;
    background-color: #fff;
    width: 80px;
    height: 80px;
    font-size: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-slider-section .swiper-button-next::after,
  .hero-slider-section .swiper-button-prev::after {
    font-size: 0px;
    content: '';
  }

  .swiper-button-next svg,
  .swiper-button-prev svg {
    width: 50%;
    height: 50%;
    max-width: 40%;
  }

  .hero-slider-section .swiper-button-prev {
    left: 50px;
    right: auto;
  }
  .hero-slider-section .swiper-button-disabled {
    opacity: 0.3;
  }
</style>

<section class="hero-slider-section">
  <div class="swiper hero-swiper {% if section.settings.page_width == 'fixed_width' %}container container-xxl mx-auto{% endif %}">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        <div
          class="swiper-slide d-flex align-items-center py-lg-21 px-0"
          style="height: {{ section.settings.slider_max_height | default: '100vh' }};"
          {{ block.shopify_attributes }}
        >
          <div class="z-index-2 container container-xxl py-21 pt-xl-10 pb-xl-11 ps-lg-19 ps-6">
            {% if block.settings.show_content %}
              {% assign bg_opacity = block.settings.content_bg_opacity | divided_by: 100.0 %}
              <div
                class="hero-content {{ block.settings.text_alignment | default: 'text-start' }} p-6"
                style="{% if block.settings.content_bg_color != blank and block.settings.content_bg_color != 'rgba(0,0,0,0)' %}background-color: {{ block.settings.content_bg_color | color_modify: 'alpha', bg_opacity }}; border-radius: 8px;{% endif %} max-width: 600px; {% if block.settings.text_alignment == 'text-center' %}margin: 0 auto;{% elsif block.settings.text_alignment == 'text-end' %}margin-left: auto; margin-right: 0;{% endif %}"
                data-animate="fadeInUp"
              >
                <div>
                  {% if block.settings.title != blank %}
                    <h1
                      class="mb-7 hero-title fs-1"
                      {% if block.settings.heading_color != blank and block.settings.heading_color != 'rgba(0,0,0,0)' %}
                        style="color: {{ block.settings.heading_color }};"
                      {% endif %}
                    >
                      {{ block.settings.title }}
                    </h1>
                  {% endif %}
                  {% if block.settings.text != blank %}
                    <p
                      class="hero-desc fs-18px mb-11"
                      {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}
                        style="color: {{ block.settings.text_color }};"
                      {% endif %}
                    >
                      {{ block.settings.text }}
                    </p>
                  {% endif %}
                  {% if block.settings.subtext != blank %}
                    <p class="fs-5 fw-semibold text-body-emphasis mb-7">{{ block.settings.subtext }}</p>
                  {% endif %}
                </div>
                {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                  <a
                    href="{{ block.settings.button_link }}"
                    class="btn btn-dark rounded btn-hover-bg-primary btn-hover-border-primary"
                  >
                    {{ block.settings.button_label }}
                  </a>
                {% endif %}
              </div>
            {% endif %}
          </div>

          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1920
              | image_tag:
                class: 'lazy-bg bg-overlay position-absolute z-index-1 w-100 h-100 object-fit-cover light-mode-img',
                loading: 'lazy'
            }}
          {% endif %}
          {% if block.settings.image_dark != blank %}
            {{
              block.settings.image_dark
              | image_url: width: 1920
              | image_tag:
                class: 'lazy-bg bg-overlay position-absolute z-index-1 w-100 h-100 object-fit-cover dark-mode-img',
                loading: 'lazy'
            }}
          {% elsif block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1920
              | image_tag:
                class: 'lazy-bg bg-overlay position-absolute z-index-1 w-100 h-100 object-fit-cover dark-mode-img',
                loading: 'lazy'
            }}
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if section.settings.show_dots %}
      <div class="swiper-pagination"></div>
    {% endif %}

    {% if section.settings.show_arrows %}
      <div class="swiper-button-next">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-move-right-icon lucide-move-right"
        >
          <path d="M18 8L22 12L18 16" />
          <path d="M2 12H22" />
        </svg>
      </div>
      <div class="swiper-button-prev">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-move-left-icon lucide-move-left"
        >
          <path d="M6 8L2 12L6 16" />
          <path d="M2 12H22" />
        </svg>
      </div>
    {% endif %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var swiper = new Swiper('.hero-swiper', {
      loop: true,
      autoplay: {{ section.settings.autoplay | default: 'false' }} ? {
        delay: {{ section.settings.speed }},
        disableOnInteraction: false, // keep autoplay after swipe
        pauseOnMouseEnter: true, // pause on hover
      } : false,
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      effect: 'fade',
      fadeEffect: {
        crossFade: true
      }
    });
  });
</script>

{% schema %}
{
  "name": "Hero Slider",
  "settings": [
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "text",
      "id": "slider_max_height",
      "label": "Max Slider Height",
      "info": "e.g. 100vh, 600px, 40rem",
      "default": "100vh"
    },
    {
      "type": "select",
      "id": "page_width",
      "label": "Section Width",
      "options": [
        {
          "value": "full_width",
          "label": "Full Width"
        },
        {
          "value": "fixed_width",
          "label": "Fixed Width"
        }
      ],
      "default": "full_width"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 1000,
      "max": 5000,
      "step": 500,
      "unit": "ms",
      "label": "Autoplay Delay",
      "default": 3000
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrows",
      "default": true
    },
    {
      "type": "header",
      "content": "Custom Styling"
    },
    {
      "type": "header",
      "content": "Spacing Setting"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "text",
      "id": "margin_desktop",
      "label": "Margin",
      "info": "Format: top right bottom left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "text",
      "id": "padding_desktop",
      "label": "Padding",
      "info": "Format: top right bottom left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "text",
      "id": "margin_mobile",
      "label": "Margin",
      "info": "Format: top right bottom left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "text",
      "id": "padding_mobile",
      "label": "Padding",
      "info": "Format: top right bottom left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "header",
      "content": "Background Setting"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "section_bg_image",
      "label": "Background Image"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (Light/Default)"
        },
        {
          "type": "image_picker",
          "id": "image_dark",
          "label": "Image (Dark Mode)"
        },
        {
          "type": "header",
          "content": "Slide Settings"
        },
        {
          "type": "checkbox",
          "id": "show_content",
          "label": "Show Content",
          "default": true
        },
        {
          "type": "select",
          "id": "text_alignment",
          "label": "Text Alignment",
          "options": [
            {
              "value": "text-start",
              "label": "Left"
            },
            {
              "value": "text-center",
              "label": "Center"
            },
            {
              "value": "text-end",
              "label": "Right"
            }
          ],
          "default": "text-start"
        },
        {
          "type": "color",
          "id": "content_bg_color",
          "label": "Content Background Color"
        },
        {
          "type": "range",
          "id": "content_bg_opacity",
          "min": 0,
          "max": 100,
          "step": 10,
          "unit": "%",
          "label": "Content Background Opacity",
          "default": 100
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading Color"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Description Color"
        },
        {
          "type": "textarea",
          "id": "title",
          "label": "Heading",
          "default": "Reveal The<br>Beauty of Skin"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Made using clean, non-toxic ingredients, our products are designed for everyone."
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "Starting at $7.99"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
