{% render 'section-style' %}

<div class="global-heading-section container">
  <div class="row">
    <div class="col-12 {{ section.settings.text_alignment }}">
      {% if section.settings.heading != blank %}
        <h2
          class="section-heading mb-3"
          style="{% if section.settings.text_color != blank and section.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ section.settings.text_color }};{% endif %} font-size: {{ section.settings.heading_size }}px;"
        >
          {{ section.settings.heading }}
        </h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <div
          class="section-subheading"
          style="{% if section.settings.subheading_color != blank and section.settings.subheading_color != 'rgba(0,0,0,0)' %}color: {{ section.settings.subheading_color }};{% endif %} font-size: {{ section.settings.subheading_size }}px;"
        >
          {{ section.settings.subheading }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Global Heading",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Section Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Add a description or subheading here."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "text-start",
          "label": "Left"
        },
        {
          "value": "text-center",
          "label": "Center"
        },
        {
          "value": "text-end",
          "label": "Right"
        }
      ],
      "default": "text-center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading Color"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Heading Font Size",
      "default": 32
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Subheading Font Size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Custom Styling"
    },
    {
      "type": "header",
      "content": "Spacing Setting"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "text",
      "id": "margin_desktop",
      "label": "Margin",
      "info": "Format: top right bottom left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "text",
      "id": "padding_desktop",
      "label": "Padding",
      "info": "Format: top right bottom left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "text",
      "id": "margin_mobile",
      "label": "Margin",
      "info": "Format: top right bottom left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "text",
      "id": "padding_mobile",
      "label": "Padding",
      "info": "Format: top right bottom left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "header",
      "content": "Background Setting"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "section_bg_image",
      "label": "Background Image"
    }
  ],
  "presets": [
    {
      "name": "Global Heading"
    }
  ]
}
{% endschema %}
