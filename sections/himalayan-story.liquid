{% render 'section-style' %}

<div class="himalayan-story-section py-15 bg-light overflow-hidden" id="story-section-{{ section.id }}">
  <div class="container container-xxl">
    
    <div class="row justify-content-center text-center mb-12">
      <div class="col-lg-8">
        {% if section.settings.subheading != blank %}
          <span class="text-uppercase fw-bold ls-2 text-primary fs-14px d-block mb-4">{{ section.settings.subheading }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="h1 fw-bold text-body-emphasis mb-6">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <p class="fs-18px text-muted mb-0">{{ section.settings.text }}</p>
        {% endif %}
      </div>
    </div>

    <div class="story-timeline position-relative">
      {% for block in section.blocks %}
        {% assign is_even = forloop.index0 | modulo: 2 %}
        <div class="story-item row align-items-center mb-13 gy-8" {{ block.shopify_attributes }}>
          <div class="col-lg-6 {% if is_even == 1 %}order-lg-2{% endif %} story-image-col">
            <div class="story-image-wrapper rounded-4 overflow-hidden shadow-sm hover-zoom-in">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 800 | image_tag: class: 'img-fluid w-100 object-fit-cover', style: 'max-height: 450px;', loading: 'lazy' }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg bg-white w-100 h-100' }}
              {% endif %}
            </div>
          </div>
          <div class="col-lg-5 {% if is_even == 1 %}order-lg-1 offset-lg-1{% else %}offset-lg-1{% endif %} story-content-col">
            <div class="story-content p-4">
              <div class="story-step-badge mb-5 text-primary fw-bold fs-5">0{{ forloop.index }}.</div>
              <h3 class="h2 fw-bold text-body-emphasis mb-5">{{ block.settings.title }}</h3>
              <div class="fs-16px text-muted lh-base">{{ block.settings.text }}</div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" defer></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Register GSAP ScrollTrigger
    gsap.registerPlugin(ScrollTrigger);
    
    // Animate each story item as it enters viewport
    const storyItems = document.querySelectorAll('#story-section-{{ section.id }} .story-item');
    
    storyItems.forEach((item, index) => {
      const img = item.querySelector('.story-image-wrapper');
      const content = item.querySelector('.story-content');
      
      // Image slide-in/fade
      gsap.fromTo(img, 
        { 
          opacity: 0, 
          x: index % 2 === 0 ? -50 : 50 
        }, 
        {
          opacity: 1,
          x: 0,
          duration: 1,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: item,
            start: 'top 80%',
            toggleActions: 'play none none none'
          }
        }
      );
      
      // Content fade up
      gsap.fromTo(content,
        {
          opacity: 0,
          y: 40
        },
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          delay: 0.2,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: item,
            start: 'top 80%',
            toggleActions: 'play none none none'
          }
        }
      );
    });
  });
</script>

{% schema %}
{
  "name": "Himalayan Story",
  "max_blocks": 5,
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Section Subheading",
      "default": "Our Philosophy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "The Himalayan Story"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Introduction Text",
      "default": "How we bring the purest elements of nature from the snow peaks directly to your home."
    }
  ],
  "blocks": [
    {
      "type": "story_beat",
      "name": "Story Beat",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Step Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Hand-picked in the hills"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Step Description",
          "default": "<p>Our wild-crafted herbs and organic produce are hand-harvested by local families in high-altitude valleys.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Himalayan Story",
      "blocks": [
        {
          "type": "story_beat",
          "settings": {
            "title": "Hand-picked in the hills",
            "text": "<p>Our ingredients are carefully gathered at their peak potency by local farmers who understand the rhythm of the mountains.</p>"
          }
        },
        {
          "type": "story_beat",
          "settings": {
            "title": "Traditional Recipes, No Shortcuts",
            "text": "<p>We preserve our harvests using traditional solar-drying and fermentation techniques passed down through generations.</p>"
          }
        },
        {
          "type": "story_beat",
          "settings": {
            "title": "Hygienically Processed",
            "text": "<p>Every batch is washed, processed, and packed in state-of-the-art sterile facilities to retain natural purity and freshness.</p>"
          }
        },
        {
          "type": "story_beat",
          "settings": {
            "title": "Delivered Fresh to You",
            "text": "<p>From mountain peak to your doorstep, we preserve nutrients and flavor so you get the genuine taste of the Himalayas.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
