{% comment %} Force sync {% endcomment %}
{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "select",
      "id": "header_style",
      "label": "Header Style",
      "options": [
        {
          "value": "style_1",
          "label": "Style 1 (Default)"
        },
        {
          "value": "style_2",
          "label": "Style 2 (Logo Left, Nav Center)"
        }
      ],
      "default": "style_1"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "header_left_text",
      "label": "Header Left Text",
      "default": "Free Shipping Over $99"
    },
    {
      "type": "text",
      "id": "topbar_text",
      "label": "Announcement Text (Legacy - not used)",
      "default": "Free shipping on all U.S orders $50+"
    },
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement",
      "default": true
    },
    {
      "type": "color",
      "id": "announcement_bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "announcement_text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free shipping on all u.s"
        }
      ]
    },
    {
      "type": "mega_menu",
      "name": "Mega Menu",
      "settings": [
        {
          "type": "text",
          "id": "menu_trigger",
          "label": "Menu Item Name",
          "info": "The exact name of the menu item you want to turn into a mega menu."
        },
        {
          "type": "header",
          "content": "Promotion Banner"
        },
        {
          "type": "image_picker",
          "id": "promo_image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "promo_heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "promo_subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "promo_button_text",
          "label": "Button Text",
          "default": "Shop Sale"
        },
        {
          "type": "url",
          "id": "promo_link",
          "label": "Link"
        }
      ]
    }
  ]
}
{% endschema %}

<div class="header-wrapper">
  <header
    id="header"
    class="header header-sticky header-sticky-smart disable-transition-all z-index-5 header-{{ section.settings.header_style }}"
  >
    {% if section.settings.show_announcement %}
      <div class="topbar">
        <div class="overflow-hidden" style="background-color: {{ section.settings.announcement_bg_color }};">
          <div
            class="pt-4 pb-3 move-text-animate fw-semibold text-nowrap"
            style="color: {{ section.settings.announcement_text_color }};"
          >
            {% comment %} Repeat blocks to ensure continuous scrolling effect {% endcomment %}
            {% for i in (1..10) %}
              {% for block in section.blocks %}
                {% if block.type == 'announcement' and block.settings.text != blank %}
                  <span class="text-uppercase me-16">{{ block.settings.text }}</span>
                {% endif %}
              {% endfor %}
            {% endfor %}
          </div>
        </div>
      </div>
    {% endif %}

    {% if section.settings.header_style == 'style_1' %}
      <div class="header-above">
        <div class="container-fluid px-10 d-none d-xl-block">
          <div class="pt-5 pb-5 d-flex align-items-center justify-content-center">
            <div class="icons-actions d-flex justify-content-start align-items-center w-xl-50 fs-16px text-body-emphasis fw-bold text-uppercase ls-1">
              {{ section.settings.header_left_text }}
            </div>

            <a href="{{ routes.root_url }}" class="navbar-brand px-8 py-4 mx-auto">
              {%- assign logo = settings.logo -%}
              {%- assign logo_width = settings.logo_width -%}
              {% if logo != blank %}
                {{
                  logo
                  | image_url: width: logo_width
                  | image_tag: class: 'light-mode-img', loading: 'lazy', alt: shop.name
                }}
                {{
                  logo
                  | image_url: width: logo_width
                  | image_tag: class: 'dark-mode-img', loading: 'lazy', alt: shop.name
                }}
              {% else %}
                <span class="h3">{{ shop.name }}</span>
              {% endif %}
            </a>

            <div class="icons-actions d-flex justify-content-end w-xl-50 fs-28px text-body-emphasis">
              <div class="px-5 d-none d-xl-inline-block">
                <a
                  class="lh-1 color-inherit text-decoration-none"
                  href="#searchDrawer"
                  data-bs-toggle="offcanvas"
                  aria-controls="searchDrawer"
                  role="button"
                  aria-label="Search"
                >
                  <svg class="icon icon-magnifying-glass-light">
                    <use xlink:href="#search"></use>
                  </svg>
                </a>
              </div>
              <div class="px-5 d-none d-xl-inline-block">
                {% if customer %}
                  <a class="lh-1 color-inherit text-decoration-none" href="{{ routes.account_url }}">
                    {% render 'icon-account' %}
                  </a>
                {% else %}
                  <a class="lh-1 color-inherit text-decoration-none" href="{{ routes.account_login_url }}">
                    {% render 'icon-account' %}
                  </a>
                {% endif %}
              </div>
              <div class="px-5 d-none d-xl-inline-block">
                <a class="position-relative lh-1 color-inherit text-decoration-none" href="/pages/wishlist">
                  <svg class="icon icon-star-light">
                    <use xlink:href="#icon-star-light"></use>
                  </svg>
                  <span
                    class="badge bg-dark text-white position-absolute top-0 start-100 translate-middle mt-4 rounded-circle fs-13px p-0 square wishlist-count-badge"
                    style="--square-size: 18px"
                    >0</span
                  >
                </a>
              </div>
              <div class="px-5 d-none d-xl-inline-block">
                <a
                  class="position-relative lh-1 color-inherit text-decoration-none"
                  href="#"
                  data-bs-toggle="offcanvas"
                  data-bs-target="#shoppingCart"
                  aria-controls="shoppingCart"
                >
                  {% render 'icon-cart' %}
                  <span
                    class="badge bg-dark text-white position-absolute top-0 start-100 translate-middle mt-4 rounded-circle fs-13px p-0 square cart-count-badge"
                    style="--square-size: 18px"
                  >
                    {{- cart.item_count -}}
                  </span>
                </a>
              </div>

              <!-- Theme Toggle -->
              <div class="theme-mode position-relative ps-5">
                <a
                  class="bd-theme btn btn-link nav-link d-inline-flex align-items-center justify-content-center p-0 position-relative rounded-circle"
                  href="#"
                  aria-label="Toggle theme"
                >
                  <svg class="icon bi my-1 theme-icon-active">
                    <use href="#sun-fill"></use>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="sticky-area">
        <div class="main-header nav navbar navbar-light navbar-expand-xl py-6 py-xl-0">
          <div class="container-fluid">
            <!-- Mobile Logo & Toggle -->
            <div class="d-flex d-xl-none w-100">
              <div class="w-72px d-flex d-xl-none">
                <button
                  class="navbar-toggler align-self-center border-0 shadow-none px-0 canvas-toggle p-4"
                  type="button"
                  data-bs-toggle="offcanvas"
                  data-bs-target="#offCanvasNavBar"
                  aria-controls="offCanvasNavBar"
                  aria-expanded="false"
                  aria-label="Toggle Navigation"
                >
                  <span class="fs-24 toggle-icon"></span>
                </button>
              </div>

              <div class="d-flex mx-auto">
                <a href="{{ routes.root_url }}" class="navbar-brand px-8 py-4 mx-auto">
                  {%- liquid
                    assign logo = settings.logo
                    assign logo_width = settings.logo_width_mobile | default: 90
                  -%}
                  {% if logo != blank %}
                    {{
                      logo
                      | image_url: width: logo_width
                      | image_tag: class: 'light-mode-img', loading: 'lazy', alt: shop.name
                    }}
                    {{
                      logo
                      | image_url: width: logo_width
                      | image_tag: class: 'dark-mode-img', loading: 'lazy', alt: shop.name
                    }}
                  {% else %}
                    <span>{{ shop.name }}</span>
                  {% endif %}
                </a>
              </div>

              <div class="icons-actions d-flex justify-content-end w-xl-50 fs-28px text-body-emphasis w-72px">
                <div class="px-xl-5 d-inline-block">
                  <a
                    class="lh-1 color-inherit text-decoration-none"
                    href="#"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#searchModal"
                    aria-controls="searchModal"
                    aria-expanded="false"
                  >
                    <svg class="icon icon-magnifying-glass-light">
                      <use xlink:href="#search"></use>
                    </svg>
                  </a>
                </div>

                <!-- Mobile Theme Toggle -->
                <div class="color-modes position-relative ps-5">
                  <a
                    class="bd-theme btn btn-link nav-link d-inline-flex align-items-center justify-content-center text-primary p-0 position-relative rounded-circle"
                    href="#"
                    aria-label="Toggle theme"
                  >
                    <svg class="bi my-1 theme-icon-active">
                      <use href="#sun-fill"></use>
                    </svg>
                  </a>
                </div>
              </div>
            </div>

            <!-- Desktop Menu -->
            <div class="w-100 d-none d-xl-flex align-items-center justify-content-center">
              <ul class="navbar-nav">
                {% for link in linklists[section.settings.menu].links %}
                  {% assign mega_block = null %}
                  {% for block in section.blocks %}
                    {% if block.settings.menu_trigger == link.title %}
                      {% assign mega_block = block %}
                      {% break %}
                    {% endif %}
                  {% endfor %}

                  {% if mega_block %}
                    <!-- Mega Menu Item -->
                    <li class="nav-item transition-all-xl-1 py-0 dropdown dropdown-fullwidth position-static">
                      <a
                        class="nav-link d-flex justify-content-between position-relative text-uppercase fw-semibold ls-1 fs-15px dropdown-toggle"
                        href="{{ link.url }}"
                        data-bs-toggle="dropdown"
                        aria-haspopup="true"
                        aria-expanded="false"
                      >
                        {{- link.title -}}
                      </a>
                      <div class="dropdown-menu mega-menu start-0 py-6 w-100">
                        <div class="megamenu-shop container-wide py-8 px-12">
                          <div class="row">
                            <!-- Menu Columns -->
                            {% for childlink in link.links %}
                              <div class="col">
                                <h6 class="fs-18px">{{ childlink.title }}</h6>
                                <ul class="list-unstyled mb-0">
                                  {% for grandchildlink in childlink.links %}
                                    <li>
                                      <a
                                        href="{{ grandchildlink.url }}"
                                        class="border-hover text-decoration-none py-3 d-block"
                                      >
                                        <span class="border-hover-target">{{ grandchildlink.title }}</span>
                                      </a>
                                    </li>
                                  {% endfor %}
                                </ul>
                              </div>
                            {% endfor %}

                            <!-- Promotion Banner -->
                            {% if mega_block.settings.promo_image != blank %}
                              <div class="col d-xxl-block d-none megamenu-shop-banner" data-bs-theme="light">
                                <div class="card border-0 mt-4">
                                  {{
                                    mega_block.settings.promo_image
                                    | image_url: width: 600
                                    | image_tag: class: 'card-img', alt: mega_block.settings.promo_heading
                                  }}
                                  <div class="card-img-overlay d-flex flex-column mx-2 px-9 py-6">
                                    {% if mega_block.settings.promo_subheading != blank %}
                                      <p class="text-body-emphasis ls-1 fw-semibold mb-4 mt-6 text-uppercase">
                                        {{ mega_block.settings.promo_subheading }}
                                      </p>
                                    {% endif %}
                                    {% if mega_block.settings.promo_heading != blank %}
                                      <h3 class="fs-3">{{ mega_block.settings.promo_heading }}</h3>
                                    {% endif %}
                                    {% if mega_block.settings.promo_button_text != blank %}
                                      <div class="mt-auto">
                                        <a href="{{ mega_block.settings.promo_link }}" class="btn btn-white">
                                          {{- mega_block.settings.promo_button_text -}}
                                        </a>
                                      </div>
                                    {% endif %}
                                  </div>
                                </div>
                              </div>
                            {% endif %}
                          </div>
                        </div>
                      </div>
                    </li>
                  {% elsif link.links != blank %}
                    <!-- Standard Dropdown -->
                    <li class="nav-item transition-all-xl-1 py-xl-7 py-0 me-xxl-12 me-xl-10 dropdown dropdown-hover">
                      <a
                        class="nav-link d-flex justify-content-between position-relative py-xl-0 px-xl-0 fw-semibold ls-1 fs-6 fs-xl-15px dropdown-toggle"
                        href="{{ link.url }}"
                        data-bs-toggle="dropdown"
                        aria-haspopup="true"
                        aria-expanded="false"
                      >
                        {{- link.title -}}
                      </a>
                      <ul class="dropdown-menu py-6">
                        {% for childlink in link.links %}
                          <li>
                            <a class="dropdown-item border-hover" href="{{ childlink.url }}">
                              <span class="border-hover-target">{{ childlink.title }}</span>
                            </a>
                          </li>
                        {% endfor %}
                      </ul>
                    </li>
                  {% else %}
                    <!-- Single Link -->
                    <li class="nav-item transition-all-xl-1 py-xl-7 py-0 me-xxl-12 me-xl-10">
                      <a
                        class="nav-link d-flex justify-content-between position-relative py-xl-0 px-xl-0 fw-semibold ls-1 fs-6 fs-xl-15px"
                        href="{{ link.url }}"
                      >
                        {{- link.title -}}
                      </a>
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>
          </div>
        </div>
      </div>
    {% elsif section.settings.header_style == 'style_2' %}
      <div class="sticky-area">
        <div class="main-header nav navbar bg-body navbar-light navbar-expand-xl py-4 py-xl-0">
          <div class="container-wide container d-flex align-items-center justify-content-between">
            <!-- Left Section: Mobile Toggle & Desktop Menu -->
            <div class="d-flex align-items-center justify-content-start w-xl-50">
              <!-- Mobile Toggle -->
              <div class="d-flex d-xl-none me-3">
                <button
                  class="navbar-toggler border-0 shadow-none px-0"
                  type="button"
                  data-bs-toggle="offcanvas"
                  data-bs-target="#offCanvasNavBar"
                  aria-controls="offCanvasNavBar"
                  aria-label="Toggle Navigation"
                >
                  <span class="fs-24">
                    <svg class="icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"></path>
                    </svg>
                  </span>
                </button>
              </div>

              <!-- Desktop Menu -->
              <div class="d-none d-xl-flex">
                <ul class="navbar-nav">
                  {% for link in linklists[section.settings.menu].links %}
                    {% assign mega_block = null %}
                    {% for block in section.blocks %}
                      {% if block.settings.menu_trigger == link.title %}
                        {% assign mega_block = block %}
                        {% break %}
                      {% endif %}
                    {% endfor %}

                    {% if mega_block %}
                      <li class="nav-item py-0 dropdown dropdown-fullwidth position-static">
                        <a
                          class="nav-link text-uppercase fw-semibold ls-1 fs-15px dropdown-toggle"
                          href="{{ link.url }}"
                          data-bs-toggle="dropdown"
                          aria-haspopup="true"
                          aria-expanded="false"
                        >
                          {{- link.title -}}
                        </a>
                        <div class="dropdown-menu mega-menu start-0 py-6 w-100">
                          <div class="megamenu-shop container-wide py-8 px-12">
                            <div class="row">
                              {% for childlink in link.links %}
                                <div class="col">
                                  <h6 class="fs-18px">{{ childlink.title }}</h6>
                                  <ul class="list-unstyled mb-0">
                                    {% for grandchildlink in childlink.links %}
                                      <li>
                                        <a
                                          href="{{ grandchildlink.url }}"
                                          class="border-hover text-decoration-none py-3 d-block"
                                        >
                                          <span class="border-hover-target">{{ grandchildlink.title }}</span>
                                        </a>
                                      </li>
                                    {% endfor %}
                                  </ul>
                                </div>
                              {% endfor %}
                              {% if mega_block.settings.promo_image != blank %}
                                <div class="col d-none d-xxl-block">
                                  <div class="card border-0 mt-4">
                                    {{
                                      mega_block.settings.promo_image
                                      | image_url: width: 600
                                      | image_tag: class: 'card-img'
                                    }}
                                  </div>
                                </div>
                              {% endif %}
                            </div>
                          </div>
                        </div>
                      </li>
                    {% elsif link.links != blank %}
                      <li class="nav-item py-0 dropdown dropdown-hover me-xl-10">
                        <a class="nav-link fw-semibold ls-1 fs-15px dropdown-toggle" href="{{ link.url }}">
                          {{- link.title -}}
                        </a>
                        <ul class="dropdown-menu py-6">
                          {% for childlink in link.links %}
                            <li>
                              <a class="dropdown-item border-hover" href="{{ childlink.url }}">
                                <span class="border-hover-target">{{ childlink.title }}</span>
                              </a>
                            </li>
                          {% endfor %}
                        </ul>
                      </li>
                    {% else %}
                      <li class="nav-item py-0 me-xl-10">
                        <a class="nav-link fw-semibold ls-1 fs-15px" href="{{ link.url }}">
                          {{- link.title -}}
                        </a>
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </div>
            </div>

            <!-- Center Section: Logo -->
            <a href="{{ routes.root_url }}" class="navbar-brand mx-auto">
              {%- liquid
                assign logo = settings.logo
                assign logo_width = settings.logo_width
              -%}
              {% if logo != blank %}
                {{
                  logo
                  | image_url: width: logo_width
                  | image_tag: class: 'light-mode-img', loading: 'lazy', alt: shop.name
                }}
                {{
                  logo
                  | image_url: width: logo_width
                  | image_tag: class: 'dark-mode-img', loading: 'lazy', alt: shop.name
                }}
              {% else %}
                <span class="h3 mb-0">{{ shop.name }}</span>
              {% endif %}
            </a>

            <!-- Right Section: Icons -->
            <div class="d-flex justify-content-end align-items-center w-xl-50 icons-actions text-body-emphasis">
              <div class="px-5 px-xl-5">
                <a class="lh-1 color-inherit" href="#searchDrawer" data-bs-toggle="offcanvas" role="button">
                  <svg class="icon icon-magnifying-glass-light">
                    <use xlink:href="#search"></use>
                  </svg>
                </a>
              </div>
              <div class="d-none d-xl-block px-xl-5">
                <a class="lh-1 color-inherit" href="{{ routes.account_url }}">{% render 'icon-account' %}</a>
              </div>
              <div class="d-none d-xl-block px-xl-5">
                <a class="lh-1 color-inherit position-relative" href="/pages/wishlist">
                  <svg class="icon icon-star-light">
                    <use xlink:href="#icon-star-light"></use>
                  </svg>
                  <span
                    class="badge bg-dark rounded-circle position-absolute top-0 start-100 translate-middle p-0 fs-11px"
                    style="width:18px;height:18px;display:flex;align-items:center;justify-content:center;"
                    >0</span
                  >
                </a>
              </div>
              <div class="px-5 px-xl-5">
                <a
                  class="lh-1 color-inherit position-relative"
                  href="#"
                  data-bs-toggle="offcanvas"
                  data-bs-target="#shoppingCart"
                >
                  {% render 'icon-cart' %}
                  <span
                    class="badge bg-dark rounded-circle position-absolute top-0 start-100 translate-middle p-0 fs-11px"
                    style="width:18px;height:18px;display:flex;align-items:center;justify-content:center;"
                  >
                    {{- cart.item_count -}}
                  </span>
                </a>
              </div>
              <div class="ps-5 ps-xl-5 theme-mode">
                <a class="bd-theme btn btn-link nav-link p-0" href="#">
                  <svg class="icon bi my-1 theme-icon-active">
                    <use href="#sun-fill"></use>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endif %}
    {% render 'mobile-menu' %}
  </header>
</div>
