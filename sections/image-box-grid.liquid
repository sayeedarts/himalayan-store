{% render 'section-style' %}
<section class="image-box-grid-section pt-14 pt-lg-16 pb-8 pb-md-12 pb-lg-16">
  <div class="container container-xxl">
    <div class="mb-11">
      <div class="text-center" data-animate="fadeInUp">
        {% if section.settings.title != blank %}
          <h2 class="mb-6">{{ section.settings.title }}</h2>
        {% endif %}
      </div>
    </div>
    <div class="row gx-30px gy-30px row-cols-1 row-cols-md-{{ section.settings.columns_desktop }}">
      {% for block in section.blocks %}
        <div class="col mb-9 mb-md-0" data-animate="fadeInUp" {{ block.shopify_attributes }}>
          <div class="card border-0 hover-zoom-in">
            <div class="image-box-4">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 960
                  | image_tag: class: 'lazy-image img-fluid', loading: 'lazy'
                }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'lazy-image img-fluid' }}
              {% endif %}
            </div>
            <div class="card-body text-body-emphasis text-center pt-9 mt-2">
              {% if block.settings.heading != blank %}
                <h5 class="card-title text-decoration-none fs-4 d-block fw-semibold">
                  <a class="color-inherit text-decoration-none" href="{{ block.settings.link }}">
                    {{- block.settings.heading -}}
                  </a>
                </h5>
              {% endif %}
              {% if block.settings.link_text != blank %}
                <a
                  href="{{ block.settings.link }}"
                  title="{{ block.settings.link_text }}"
                  class="btn btn-link fw-semibold text-body-emphasis"
                >
                  {{ block.settings.link_text }}
                  <i class="far fa-arrow-right fs-14px ps-2 ms-1"></i>
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image Box Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Heading",
      "default": "More to Discover"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Desktop Columns",
      "default": 3
    },
    {
      "type": "header",
      "content": "Custom Styling"
    },
    {
      "type": "header",
      "content": "Spacing Setting"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "text",
      "id": "margin_desktop",
      "label": "Margin",
      "info": "Format: top right bottom left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "text",
      "id": "padding_desktop",
      "label": "Padding",
      "info": "Format: top right bottom left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "text",
      "id": "margin_mobile",
      "label": "Margin",
      "info": "Format: top right bottom left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "text",
      "id": "padding_mobile",
      "label": "Padding",
      "info": "Format: top right bottom left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "header",
      "content": "Background Setting"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "section_bg_image",
      "label": "Background Image"
    }
  ],
  "blocks": [
    {
      "type": "image_box",
      "name": "Image Box",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Find a Store"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Our Store"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Box Grid",
      "blocks": [
        {
          "type": "image_box"
        },
        {
          "type": "image_box"
        },
        {
          "type": "image_box"
        }
      ]
    }
  ]
}
{% endschema %}
